    },
    {
      "object": "block",
      "type": "code",
      "code": {
        "language": "python",
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "class AgentLoop:\n    def register_command(self, cmd: str, handler: Handler, type: str = \"exact\"):\n        \"\"\"Register a custom slash command.\n        \n        Args:\n            cmd: Command string (e.g. \"/mycommand\")\n            handler: Command handler function\n            type: Command type (\"priority\", \"exact\", \"prefix\")\n        \"\"\"\n        if type == \"priority\":\n            self.commands.priority(cmd, handler)\n        elif type == \"exact\":\n            self.commands.exact(cmd, handler)\n        elif type == \"prefix\":\n            self.commands.prefix(cmd, handler)"
            }
          }
        ]
      }
    },
    {
      "object": "block",
      "type": "heading_4",
      "heading_4": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "3.1.2 命令执行 Hook"
            }
          }
        ]
      }
    },
    {
      "object": "block",
      "type": "paragraph",
      "paragraph": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "扩展 AgentHook 类，添加针对 slash 命令的 hook 点："
            }
          }
        ]
      }
    },
    {
      "object": "block",
      "type": "code",
      "code": {
        "language": "python",
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "class AgentHook:\n    # 现有方法...\n    \n    async def before_command(self, ctx: CommandContext) -> OutboundMessage | None:\n        \"\"\"Called before executing a slash command.\n        \n        Return an OutboundMessage to bypass the command execution.\n        \"\"\"\n        return None\n    \n    async def after_command(self, ctx: CommandContext, result: OutboundMessage | None) -> OutboundMessage | None:\n        \"\"\"Called after executing a slash command.\n        \n        Can modify or replace the result.\n        \"\"\"\n        return result"
            }
          }
        ]
      }
    },
