# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=*

# API Authentication (REQUIRED)
NANOBOT_API_KEY=change-me-to-secure-random-key

# NanoBOT Configuration
NANOBOT_CONFIG=/app/config.yaml
NANOBOT_WORKSPACE=/app/workspace

# Provider API Keys (if not in config.yaml)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
